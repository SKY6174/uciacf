# Browser-safe Supabase settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_or_legacy_anon_key

# Server-only settings - never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key
OPENAI_API_KEY=your_server_only_openai_api_key
OPENAI_COMMITTEE_MODEL=gpt-5.6-terra
